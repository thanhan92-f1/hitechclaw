{
    "name": "his-mini",
    "version": "1.0.0",
    "private": true,
    "description": "Mini Hospital Information System — FHIR R5, Clinical Alerts, Chatbot Integration",
    "type": "module",
    "scripts": {
        "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
        "dev:server": "tsx --watch server/index.ts",
        "dev:web": "vite",
        "build": "vite build && tsc -p tsconfig.server.json",
        "start": "node dist-server/index.js"
    },
    "dependencies": {
        "@hono/node-server": "^1.14.0",
        "@tailwindcss/vite": "^4.2.1",
        "hono": "^4.7.0",
        "lucide-react": "^0.577.0",
        "mermaid": "^11.13.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-router-dom": "^7.13.1",
        "tailwindcss": "^4.0.0"
    },
    "devDependencies": {
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^4.3.0",
        "concurrently": "^9.1.0",
        "tsx": "^4.19.0",
        "typescript": "^5.8.0",
        "vite": "^6.0.0"
    }
}
