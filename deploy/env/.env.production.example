# ============================================================
# xClaw — Production Environment Template
# Copy to .env on the production server and fill in real values
# ============================================================

NODE_ENV=production

# ─── LLM Provider ────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# ─── Provider API Keys (fill required provider) ─────────
OPENAI_API_KEY=sk-xxxx
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ─── Server ──────────────────────────────────────────────
PORT=5001
HOST=0.0.0.0
CORS_ORIGINS=https://xclaw.xdev.asia

# ─── Database (use strong passwords!) ───────────────────
PG_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DATABASE_URL=postgresql://xclaw:${PG_PASSWORD}@postgres:5432/xclaw
MONGODB_URL=mongodb://mongodb:27017/xclaw
REDIS_URL=redis://redis:6379

# ─── Auth (generate with: openssl rand -hex 32) ─────────
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_EXPIRES_IN=7d

# ─── Docker Images (pin to specific version in prod) ────
XCLAW_SERVER_IMAGE=ghcr.io/xdev-asia/xclaw-server:latest
XCLAW_WEB_IMAGE=ghcr.io/xdev-asia/xclaw-web:latest

# ─── Agent ───────────────────────────────────────────────
AGENT_PERSONA=You are xClaw, a helpful AI assistant.
MAX_TOOL_ITERATIONS=10
TOOL_TIMEOUT=30000

# ─── Memory ──────────────────────────────────────────────
MEMORY_ENABLED=true
MAX_HISTORY=20

# ─── Channels (optional) ────────────────────────────────
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
