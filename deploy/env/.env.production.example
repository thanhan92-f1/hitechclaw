# ============================================================
# HiTechClaw — Production Environment Template
# Copy to .env on the production server and fill in real values
# ============================================================

NODE_ENV=production

# ─── LLM Provider ────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# ─── Provider API Keys (fill required provider) ─────────
OPENAI_API_KEY=sk-xxxx
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ─── Server ──────────────────────────────────────────────
PORT=5001
HOST=0.0.0.0
CORS_ORIGINS=https://hitechclaw.com

# ─── Database (use strong passwords!) ───────────────────
PG_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DATABASE_URL=postgresql://hitechclaw:${PG_PASSWORD}@postgres:5432/hitechclaw
MONGODB_URL=mongodb://mongodb:27017/hitechclaw
REDIS_URL=redis://redis:6379

# ─── Auth (generate with: openssl rand -hex 32) ─────────
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_EXPIRES_IN=7d

# ─── Docker Images (pin to specific version in prod) ────
HITECHCLAW_SERVER_IMAGE=hitechclaw/hitechclaw-server:latest
HITECHCLAW_WEB_IMAGE=hitechclaw/hitechclaw-web:latest
# ─── Agent ───────────────────────────────────────────────
AGENT_PERSONA=You are HiTechClaw, a helpful AI assistant.
MAX_TOOL_ITERATIONS=10
TOOL_TIMEOUT=30000

# ─── Memory ──────────────────────────────────────────────
MEMORY_ENABLED=true
MAX_HISTORY=20

# ─── Channels (optional) ────────────────────────────────
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
