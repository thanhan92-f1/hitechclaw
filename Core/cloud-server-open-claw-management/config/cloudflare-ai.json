{
  "agents": {
    "defaults": {
      "model": {
        "primary": "cloudflare-ai/@cf/meta/llama-3.3-70b-instruct"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "cloudflare-ai": {
        "baseUrl": "https://api.cloudflare.com/client/v4/accounts",
        "apiKey": "${CLOUDFLARE_AI_API_KEY}",
        "api": "openai-completions",
        "models": [
          { "id": "@cf/meta/llama-3.3-70b-instruct", "name": "Llama 3.3 70B" },
          { "id": "@cf/meta/llama-3.1-8b-instruct", "name": "Llama 3.1 8B" },
          { "id": "@cf/google/gemma-3-12b-it", "name": "Gemma 3 12B" },
          { "id": "@cf/mistral/mistral-7b-instruct-v0.2-lora", "name": "Mistral 7B" },
          { "id": "@cf/qwen/qwen2.5-coder-15b-instruct", "name": "Qwen 2.5 Coder 15B" },
          { "id": "@cf/deepseek-ai/deepseek-r1-distill-qwen-32b", "name": "DeepSeek R1 Distill 32B" }
        ]
      }
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "auth": {
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "trustedProxies": ["127.0.0.1", "::1", "172.16.0.0/12", "10.0.0.0/8", "192.168.0.0/16"],
    "controlUi": {
      "enabled": true,
      "allowInsecureAuth": true,
      "dangerouslyAllowHostHeaderOriginFallback": true,
      "dangerouslyDisableDeviceAuth": false
    }
  },
  "browser": {
    "headless": true,
    "defaultProfile": "openclaw",
    "noSandbox": true
  }
}
