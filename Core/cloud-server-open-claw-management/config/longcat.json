{
  "agents": {
    "defaults": {
      "model": {
        "primary": "longcat/LongCat-Flash-Lite"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "longcat": {
        "baseUrl": "https://api.longcat.chat/openai/v1",
        "apiKey": "${LONGCAT_API_KEY}",
        "api": "openai-completions",
        "authHeader": "Authorization",
        "authPrefix": "Bearer",
        "models": [
          { "id": "LongCat-Flash-Lite", "name": "LongCat Flash-Lite" },
          { "id": "LongCat-Flash-Chat", "name": "LongCat Flash-Chat" },
          { "id": "LongCat-Flash-Thinking", "name": "LongCat Flash-Thinking" },
          { "id": "LongCat-Flash-Thinking-2601", "name": "LongCat Flash-Thinking-2601" },
          { "id": "LongCat-Flash-Omni-2603", "name": "LongCat Flash-Omni-2603" }
        ]
      }
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "auth": {
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "trustedProxies": ["127.0.0.1", "::1", "172.16.0.0/12", "10.0.0.0/8", "192.168.0.0/16"],
    "controlUi": {
      "enabled": true,
      "allowInsecureAuth": true,
      "dangerouslyAllowHostHeaderOriginFallback": true,
      "dangerouslyDisableDeviceAuth": false
    }
  },
  "browser": {
    "headless": true,
    "defaultProfile": "openclaw",
    "noSandbox": true
  }
}
