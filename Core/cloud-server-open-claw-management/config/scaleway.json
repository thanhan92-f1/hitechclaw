{
  "agents": {
    "defaults": {
      "model": {
        "primary": "scaleway/qwen3-235b-a22b-instruct-2507"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "scaleway": {
        "baseUrl": "https://api.scaleway.ai/v1",
        "apiKey": "${SCALEWAY_API_KEY}",
        "api": "openai-completions",
        "models": [
          { "id": "qwen3-235b-a22b-instruct-2507", "name": "Qwen3 235B A22B (1M free tok)" },
          { "id": "llama-3.1-70b-instruct", "name": "Llama 3.1 70B" },
          { "id": "llama-3.1-8b-instruct", "name": "Llama 3.1 8B" },
          { "id": "mistral-small-3.2-24b-instruct-2506", "name": "Mistral Small 3.2" },
          { "id": "deepseek-v3-0324", "name": "DeepSeek V3" },
          { "id": "gpt-oss-120b", "name": "GPT-OSS 120B" }
        ]
      }
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "auth": {
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "trustedProxies": ["127.0.0.1", "::1", "172.16.0.0/12", "10.0.0.0/8", "192.168.0.0/16"],
    "controlUi": {
      "enabled": true,
      "allowInsecureAuth": true,
      "dangerouslyAllowHostHeaderOriginFallback": true,
      "dangerouslyDisableDeviceAuth": false
    }
  },
  "browser": {
    "headless": true,
    "defaultProfile": "openclaw",
    "noSandbox": true
  }
}
