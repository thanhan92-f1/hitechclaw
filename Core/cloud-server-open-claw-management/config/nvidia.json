{
  "agents": {
    "defaults": {
      "model": {
        "primary": "nvidia/gpt-oss-120b"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "nvidia": {
        "baseUrl": "https://integrate.api.nvidia.com/v1",
        "apiKey": "${NVIDIA_API_KEY}",
        "api": "openai-completions",
        "models": [
          { "id": "gpt-oss-120b", "name": "GPT OSS 120B" },
          { "id": "openai/gpt-oss-120b", "name": "GPT OSS 120B (OpenAI Prefix)" },
          { "id": "meta/llama-3.3-70b-instruct", "name": "Llama 3.3 70B" },
          { "id": "nvidia/llama-3.3-70b-instruct", "name": "Llama 3.3 70B (NVIDIA Prefix)" },
          { "id": "meta/llama-4-maverick-17b-128e-instruct", "name": "Llama 4 Maverick" },
          { "id": "moonshotai/kimi-k2.5", "name": "Kimi K2.5" },
          { "id": "z-ai/glm4.7", "name": "GLM 4.7" },
          { "id": "deepseek-ai/deepseek-v3.2", "name": "DeepSeek V3.2" },
          { "id": "deepseek/deepseek-r1", "name": "DeepSeek R1" },
          { "id": "nvidia/llama-3.1-70b-instruct", "name": "Llama 3.1 70B" },
          { "id": "nvidia/llama-3.1-405b-instruct", "name": "Llama 3.1 405B" }
        ]
      }
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "auth": {
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "trustedProxies": ["127.0.0.1", "::1", "172.16.0.0/12", "10.0.0.0/8", "192.168.0.0/16"],
    "controlUi": {
      "enabled": true,
      "allowInsecureAuth": true,
      "dangerouslyAllowHostHeaderOriginFallback": true,
      "dangerouslyDisableDeviceAuth": false
    }
  },
  "browser": {
    "headless": true,
    "defaultProfile": "openclaw",
    "noSandbox": true
  }
}
