{
  "agents": {
    "defaults": {
      "model": {
        "primary": "pollinations/openai"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "pollinations": {
        "baseUrl": "https://text.pollinations.ai/openai",
        "apiKey": "${POLLINATIONS_API_KEY}",
        "api": "openai-completions",
        "models": [
          { "id": "openai", "name": "GPT via Pollinations" },
          { "id": "claude", "name": "Claude via Pollinations" },
          { "id": "gemini", "name": "Gemini via Pollinations" },
          { "id": "deepseek", "name": "DeepSeek via Pollinations" },
          { "id": "llama", "name": "Llama via Pollinations" },
          { "id": "mistral", "name": "Mistral via Pollinations" }
        ]
      }
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "auth": {
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "trustedProxies": ["127.0.0.1", "::1", "172.16.0.0/12", "10.0.0.0/8", "192.168.0.0/16"],
    "controlUi": {
      "enabled": true,
      "allowInsecureAuth": true,
      "dangerouslyAllowHostHeaderOriginFallback": true,
      "dangerouslyDisableDeviceAuth": false
    }
  },
  "browser": {
    "headless": true,
    "defaultProfile": "openclaw",
    "noSandbox": true
  }
}
